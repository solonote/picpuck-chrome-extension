{
  "manifest_version": 3,
  "name": "PicPuck",
  "version": "0.1.0",
  "description": "PicPuck 编排：即梦 / Gemini 等站点 Agent（按设计文档分层实现）",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "PicPuck"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://jimeng.jianying.com/*",
        "https://gemini.google.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["src/content/picpuckAgentContent.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["tabs", "windows", "scripting", "clipboardWrite", "storage"],
  "host_permissions": [
    "https://jimeng.jianying.com/*",
    "https://gemini.google.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/core/injectHelpersMainWorld.js",
        "src/agents/jimeng/jimengImageMainWorld.js",
        "src/agents/gemini/geminiImageMainWorld.js"
      ],
      "matches": [
        "https://jimeng.jianying.com/*",
        "https://gemini.google.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ]
    }
  ]
}
